# Fase 2 — Supabase Auth y planes
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fase 2.3 — Service role de Supabase (solo server-only, bypasea RLS).
# La usa el webhook de Mercado Pago para actualizar `companies` sin
# sesión de usuario. NUNCA exponerla al cliente (sin prefijo NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# Fase 2.3 — Mercado Pago Preapproval
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# URL pública de la app (usada como back_url de Mercado Pago, que
# exige HTTPS y no acepta http://localhost). En producción, la URL de Vercel.
NEXT_PUBLIC_APP_URL=https://radarstock.vercel.app

# Fase 2.4 — SendGrid (emails transaccionales)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Fase 3.6 — Backend ML (radarstock-ml/). INTERNAL_SERVICE_TOKEN debe
# tener el mismo valor que INTERNAL_SERVICE_TOKEN en radarstock-ml/.env.
ML_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_TOKEN=

# Fase 4 — protege app/api/cron/check-alerts. Vercel manda este valor
# automáticamente como header Authorization en las invocaciones de cron
# programadas en vercel.json; solo hace falta setearlo acá (no se
# comparte con ningún otro servicio, a diferencia de INTERNAL_SERVICE_TOKEN).
CRON_SECRET=

# Plan Corporate — destino del email cuando alguien envía el formulario
# "Conversemos" en la landing o en /billing. Por defecto comercial@radarstock.cl.
SALES_EMAIL=comercial@radarstock.cl
